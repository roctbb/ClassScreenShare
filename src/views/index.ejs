<div class="entry-page">
    <section class="entry-panel">
        <div class="entry-brand">
            <span class="brand-mark brand-mark-lg">CS</span>
            <span>ClassScreenShare</span>
        </div>
        <h1>Вход в экзамен</h1>
        <p class="muted">Введите код экзамена, который выдал преподаватель. Вы будете перенаправлены на авторизацию через GeekClass.</p>

        <% if (error === 'bad_code') { %>
        <div class="alert alert-error">
            Неверный код экзамена.
        </div>
        <% } %>

        <form method="get" action="/exam" class="join-code-form">
            <label for="code">Код экзамена</label>
            <div class="join-code-row">
                <input
                    id="code"
                    type="text"
                    name="code"
                    placeholder="Например: ALGEBRA-9"
                    required
                    autocomplete="off"
                    autofocus
                />
                <button type="submit" class="btn">Войти</button>
            </div>
        </form>
    </section>
</div>
