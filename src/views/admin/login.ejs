<div class="auth-page">
    <div class="auth-card">
        <div class="entry-brand auth-brand">
            <span class="brand-mark">CS</span>
            <span>ClassScreenShare</span>
        </div>
        <h1>Вход в систему</h1>
        <% if (error === 'invalid') { %>
        <div class="alert alert-error">Неверный логин или пароль.</div>
        <% } else if (error === 'empty') { %>
        <div class="alert alert-error">Заполните оба поля.</div>
        <% } %>

        <form method="post" action="/auth/login">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="next" value="<%= next %>" />
            <div class="form-group">
                <label for="login">Логин</label>
                <input
                    type="text"
                    id="login"
                    name="login"
                    autocomplete="username"
                    required
                    autofocus
                />
            </div>
            <div class="form-group">
                <label for="password">Пароль</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    autocomplete="current-password"
                    required
                />
            </div>
            <button type="submit" class="btn">Войти</button>
        </form>

        <% if (geekclassEnabled) { %>
        <div class="auth-divider"><span>или</span></div>
        <a
            class="btn btn-secondary auth-btn-block"
            href="/auth/geekclass?next=<%= encodeURIComponent(next) %>"
        >
            Войти через GeekClass
        </a>
        <% } %>
    </div>
</div>
