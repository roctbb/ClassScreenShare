<% const joinedAt = participant.joinedAt ?? participant.joined_at; %> <% const lastSeenAt =
participant.lastSeenAt ?? participant.last_seen_at; %> <% const recordingStatus = recording &&
recording.status ? recording.status : ''; %> <% const durationMs = recording ? (recording.durationMs
?? recording.duration_ms) : null; %> <% const sizeBytes = recording ? (recording.sizeBytes ??
recording.size_bytes) : null; %> <% const hasVideoMeta = durationMs != null && sizeBytes != null; %>
<% const hasConnectionEvents = connectionSummary && connectionSummary.totalSessions > 0; %> <% const
examStartedAt = exam.startedAt ?? exam.started_at; %>
<div class="page participant-page">
    <div class="participant-top-strip">
        <a
            class="back-link participant-back-link"
            href="/admin/exams/<%= exam.id %>"
            title="К экзамену <%= exam.name %>"
            ><i class="fas fa-arrow-left"></i
        ></a>
        <div class="participant-title">
            <h1><%= participant.name %></h1>
            <p class="page-subtitle"><%= exam.name %></p>
        </div>

        <div class="participant-compact-metrics" aria-label="Сводка участника">
            <span class="participant-metric">
                <span>Кадры</span>
                <strong><%= frameCount %></strong>
                <% if (frameCount > 0 && lastSeenAt && joinedAt) { %>
                <small
                    ><%= new Date(joinedAt).toLocaleTimeString('ru-RU',
                    {hour:'2-digit',minute:'2-digit'}) %>–<%= new
                    Date(lastSeenAt).toLocaleTimeString('ru-RU', {hour:'2-digit',minute:'2-digit'})
                    %></small
                >
                <% } %>
            </span>
            <span class="participant-metric">
                <span>Сессий</span>
                <strong><%= hasConnectionEvents ? connectionSummary.totalSessions : '—' %></strong>
                <% if (hasConnectionEvents && connectionSummary.totalAbsenceLabel &&
                connectionSummary.totalAbsenceMs > 0) { %>
                <small class="summary-danger"><%= connectionSummary.totalAbsenceLabel %></small>
                <% } %>
            </span>
            <span class="participant-metric">
                <span>Видео</span>
                <% if (recordingStatus === 'done') { %>
                <strong><i class="fas fa-check"></i> готово</strong>
                <% } else if (recordingStatus === 'pending' || recordingStatus === 'running') { %>
                <strong><i class="fas fa-spinner fa-spin"></i> конв.</strong>
                <% } else if (recordingStatus === 'failed') { %>
                <strong class="summary-danger"><i class="fas fa-xmark"></i> ошибка</strong>
                <% } else if (frameCount > 0) { %>
                <strong class="muted">слайдшоу</strong>
                <% } else { %>
                <strong class="muted">—</strong>
                <% } %>
            </span>

            <details
                class="connection-log-details participant-connection-details"
                id="connection-log"
            >
                <summary class="connection-log-summary">
                    <span>Подключения</span>
                    <% if (hasConnectionEvents) { %>
                    <span
                        class="connection-state <%= connectionSummary.isOnline ? 'connection-state-online' : 'connection-state-offline' %>"
                    >
                        <span class="conn-dot"></span><%= connectionSummary.isOnline ? 'онлайн' :
                        'отключен' %>
                    </span>
                    <% } %>
                </summary>
                <div class="participant-connection-dropdown">
                    <% if (!connectionSessions || connectionSessions.length === 0) { %>
                    <p class="muted">Пока нет событий подключения.</p>
                    <% } else { %>
                    <div class="table-shell connection-log-shell">
                        <table class="data-table connection-log-table">
                            <thead>
                                <tr>
                                    <th>Начало</th>
                                    <th>Конец</th>
                                    <th>Длительность</th>
                                    <th>Статус</th>
                                    <th>Причина</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% connectionSessions.forEach(session => { %>
                                <tr>
                                    <td class="muted">
                                        <%= session.startedAt ? new
                                        Date(session.startedAt).toLocaleTimeString('ru-RU') : '—' %>
                                    </td>
                                    <td class="muted">
                                        <%= session.endedAt ? new
                                        Date(session.endedAt).toLocaleTimeString('ru-RU') : '—' %>
                                    </td>
                                    <td><%= session.durationLabel %></td>
                                    <td>
                                        <% if (session.status === 'active') { %>
                                        <span class="badge badge-active">онлайн</span>
                                        <% } else { %>
                                        <span class="badge badge-finished">завершено</span>
                                        <% } %>
                                    </td>
                                    <td class="muted"><%= session.reasonLabel || '—' %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
            </details>
        </div>

        <div class="participant-top-actions">
            <% if (frameCount > 0 && (!recording || recording.status === 'failed' ||
            recording.status === 'done')) { %>
            <form
                method="post"
                action="/admin/exams/<%= exam.id %>/participants/<%= participant.id %>/convert"
                class="inline-action-form"
            >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button
                    type="submit"
                    class="btn btn-sm btn-secondary btn-icon"
                    title="<%= recording && recording.status === 'done' ? 'Переконвертировать' : 'Конвертировать в видео' %>"
                >
                    <i class="fas fa-film"></i>
                </button>
            </form>
            <% } %> <% if (recording && recording.status === 'done') { %>
            <a
                class="btn btn-sm btn-secondary btn-icon"
                href="/admin/api/recordings/<%= recording.id %>/video?download=1"
                title="Скачать mp4"
                ><i class="fas fa-download"></i
            ></a>
            <% } %>
            <form
                method="post"
                action="/admin/exams/<%= exam.id %>/participants/<%= participant.id %>/delete"
                onsubmit="
                    return confirm('Удалить участника и все его записи? Действие необратимо.');
                "
                class="inline-action-form"
            >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-sm btn-danger btn-icon" title="Удалить">
                    <i class="fas fa-trash"></i>
                </button>
            </form>
        </div>
    </div>

    <% if (recordingStatus === 'failed') { %>
    <div class="alert alert-error">
        <strong>Ошибка конвертации:</strong>
        <details>
            <summary>Подробности</summary>
            <pre><%= recording.errorMessage ?? recording.error_message %></pre>
        </details>
    </div>
    <% } %> <% if (frameCount > 0) { %>
    <div class="card player-card" id="participant-recording">
        <div class="player-wrap">
            <img id="slideshow-img" alt="кадр" />
            <div class="player-exam-time" id="exam-time-overlay">00:00:00</div>
        </div>
        <div class="player-controls">
            <button class="btn btn-secondary btn-sm" id="play-pause">Воспроизвести</button>
            <div class="speed-buttons" id="speeds"></div>
            <div class="player-time">
                <span id="cur-time">00:00</span> / <span id="total-time">00:00</span>
            </div>
            <span id="gap-indicator" class="gap-indicator hidden"
                ><i class="fas fa-triangle-exclamation"></i> пропуск связи</span
            >
        </div>
        <div class="timeline-wrap">
            <svg
                class="timeline"
                id="timeline"
                viewBox="0 0 1000 40"
                preserveAspectRatio="none"
            ></svg>
            <div class="timeline-tooltip hidden" id="tl-tooltip"></div>
        </div>
        <div class="player-actions"></div>
    </div>

    <script>
        window.__PLAYER__ = {
            mode: 'slideshow',
            framesUrl: '/admin/api/participants/<%= participant.id %>/frames',
            frameUrlBase: '/admin/api/frames/',
            examStartedAt: <%= examStartedAt ? new Date(examStartedAt).getTime() : 'null' %>,
            connectionEvents: <%- JSON.stringify(connectionEvents || []) %>,
            maxGapSeconds: <%= typeof maxGapSeconds !== 'undefined' ? maxGapSeconds : 5 %>,
            expectedFrameIntervalMs: <%= exam.captureInterval ?? exam.capture_interval ?? 5000 %>,
            maxMissedFrames: 3,
        };
    </script>
    <script src="/js/player.js?v=<%= assetVersion %>"></script>
    <% } %>
</div>
