<div class="live-page">
    <header class="live-header">
        <a class="back-link" href="/admin/exams/<%= exam.id %>">← К экзамену</a>
        <h1>Live: <%= exam.name %></h1>
        <span id="conn-status" class="conn-status conn-disconnected">
            <span class="conn-dot"></span><span id="conn-text">Подключение…</span>
        </span>
        <div class="live-stats">
            <span>Всего: <strong id="total-count">0</strong></span>
            <span>Активных: <strong id="live-count">0</strong></span>
            <span class="muted hidden" id="disconnected-count"
                >Отключены: <strong id="disconnected-num">0</strong></span
            >
            <span class="muted hidden" id="stale-count"
                >Проблемы: <strong id="stale-num">0</strong></span
            >
        </div>
        <button class="btn btn-secondary btn-sm" type="button" id="mute-btn">Включить звук</button>
    </header>

    <div class="live-body">
        <div class="live-grid" id="grid">
            <% if (participants.length === 0) { %>
            <div class="live-empty muted" id="empty-state">
                Ожидание участников. Раздайте ссылку: <code><%- exam.code %></code>
            </div>
            <% } else { %> <% participants.forEach(p => { %>
            <div class="screen-card" data-pid="<%= p.id %>" data-name="<%= p.name %>">
                <div class="screen-name">
                    <span class="screen-name-text"><%= p.name %></span>
                    <span class="screen-since muted" data-since-for="<%= p.id %>">—</span>
                </div>
                <div class="screen-img">
                    <span class="screen-placeholder muted">Ожидание кадра…</span>
                </div>
                <div class="screen-status hidden"></div>
            </div>
            <% }) %> <% } %>
        </div>

        <aside class="live-log">
            <h3>Журнал</h3>
            <ul id="log-list"></ul>
        </aside>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    window.__LIVE__ = <%- JSON.stringify({
        examId: exam.id,
        inactivityTimeout,
        captureInterval: exam.captureInterval ?? exam.capture_interval ?? 5000,
    }) %>;
</script>
<script src="/js/live.js?v=<%= assetVersion %>"></script>
