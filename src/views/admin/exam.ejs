<% const totalFrames = participants.reduce((sum, p) => sum + (Number(p.frameCount) || 0), 0); %>
<% const recordingStatus = (p) => (p.recording && p.recording.status ? p.recording.status : ''); %>
<% const readyVideos = participants.filter((p) => recordingStatus(p) === 'done').length; %>
<% const convertingVideos = participants.filter((p) => ['pending', 'running'].includes(recordingStatus(p))).length; %>
<% const failedVideos = participants.filter((p) => recordingStatus(p) === 'failed').length; %>
<% const isActive = exam.status === 'active'; %>
<% function fmtDate(d) {
    if (!d) return '—';
    const dt = new Date(d);
    if (isNaN(dt.getTime())) return '—';
    return dt.toLocaleString('ru-RU');
} %>
<% function fmtTime(d) {
    if (!d) return '—';
    const dt = new Date(d);
    if (isNaN(dt.getTime())) return '—';
    return dt.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
} %>

<div class="page page-wide">
    <!-- Шапка: название + статус + действия -->
    <div class="exam-topbar">
        <a class="back-link" href="/admin" title="К списку экзаменов"><i class="fas fa-arrow-left"></i></a>

        <div class="exam-title-group">
            <h1 id="exam-title-display"><%= exam.name %></h1>
            <span class="badge badge-<%= exam.status %>">
                <%= exam.status === 'draft' ? 'черновик' : (exam.status === 'active' ? 'активен' : 'завершён') %>
            </span>
        </div>

        <form id="rename-form" method="post" action="/admin/exams/<%= exam.id %>/rename"
            class="inline-form hidden exam-rename-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="text" name="name" value="<%= exam.name %>" required maxlength="255" />
            <button type="submit" class="btn btn-sm" title="Сохранить"><i class="fas fa-check"></i></button>
            <button type="button" class="btn btn-sm btn-secondary" title="Отмена"
                onclick="document.getElementById('rename-form').classList.add('hidden');document.getElementById('exam-title-display').classList.remove('hidden')"><i class="fas fa-xmark"></i></button>
        </form>

        <div class="exam-topbar-actions">
            <% if (exam.status === 'draft') { %>
            <form method="post" action="/admin/exams/<%= exam.id %>/activate">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-play"></i> Запустить</button>
            </form>
            <% } else if (exam.status === 'active') { %>
            <form method="post" action="/admin/exams/<%= exam.id %>/finish"
                onsubmit="return confirm('Завершить экзамен?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-secondary btn-sm"><i class="fas fa-stop"></i> Завершить</button>
            </form>
            <% } else { %>
            <form method="post" action="/admin/exams/<%= exam.id %>/convert-all">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-secondary btn-sm" title="Конвертировать все записи в видео"><i class="fas fa-film"></i> Конвертировать все</button>
            </form>
            <% } %>

            <button class="btn btn-secondary btn-sm btn-icon" type="button" title="Переименовать"
                onclick="document.getElementById('rename-form').classList.toggle('hidden');document.getElementById('exam-title-display').classList.toggle('hidden');document.querySelector('#rename-form input[name=name]').focus()">
                <i class="fas fa-pen"></i>
            </button>

            <form method="post" action="/admin/exams/<%= exam.id %>/delete"
                onsubmit="return confirm('Удалить экзамен и все его записи? Это необратимо.');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Удалить экзамен"><i class="fas fa-trash"></i></button>
            </form>
        </div>
    </div>

    <% if (renamed) { %>
    <div class="alert alert-success">Название обновлено.</div>
    <% } %>

    <!-- Инфополоса: ссылка + статистика + параметры -->
    <div class="exam-infobar card">
        <div class="exam-infobar-invite">
            <code class="code-pill"><%= exam.code %></code>
            <input type="text" id="invite-link" value="<%= inviteUrl %>" readonly onclick="this.select()" class="invite-input" />
            <button class="btn btn-secondary btn-sm btn-icon" type="button" id="copy-invite-btn" title="Скопировать ссылку"><i class="fas fa-copy"></i></button>
            <span class="copy-feedback muted" id="copy-invite-feedback" aria-live="polite"></span>
        </div>
        <div class="exam-infobar-stats">
            <span title="Участников"><i class="fas fa-users muted"></i> <strong id="summary-participants"><%= participants.length %></strong></span>
            <span title="Кадров всего"><i class="fas fa-image muted"></i> <strong id="summary-frames"><%= totalFrames %></strong></span>
            <span title="Видео готово"><i class="fas fa-circle-check muted"></i> <strong><span id="summary-video-ready"><%= readyVideos %></span>/<%= participants.length %></strong></span>
            <% if (convertingVideos > 0) { %>
            <span class="badge badge-draft" id="summary-video-converting"><i class="fas fa-spinner fa-spin"></i> <%= convertingVideos %></span>
            <% } else { %>
            <span class="hidden" id="summary-video-converting"></span>
            <% } %>
            <% if (failedVideos > 0) { %>
            <span class="badge badge-finished summary-danger"><i class="fas fa-circle-exclamation"></i> <span id="summary-video-failed"><%= failedVideos %></span></span>
            <% } else { %>
            <span class="hidden summary-danger"><span id="summary-video-failed">0</span></span>
            <% } %>
        </div>
        <details class="exam-params-details">
            <summary class="muted"><i class="fas fa-sliders"></i> Параметры</summary>
            <dl class="kv exam-params-kv">
                <dt>Интервал:</dt><dd><%= exam.captureInterval ?? exam.capture_interval %> мс</dd>
                <dt>Качество:</dt><dd><%= exam.imageQuality ?? exam.image_quality %></dd>
                <dt>Ширина:</dt><dd><%= exam.imageWidth ?? exam.image_width %> px</dd>
                <dt>Создан:</dt><dd><%= fmtDate(exam.created_at || exam.createdAt) %></dd>
                <% const startedAt = exam.started_at || exam.startedAt; %>
                <% if (startedAt) { %><dt>Запущен:</dt><dd><%= fmtDate(startedAt) %></dd><% } %>
                <% const finishedAt = exam.finished_at || exam.finishedAt; %>
                <% if (finishedAt) { %><dt>Завершён:</dt><dd><%= fmtDate(finishedAt) %></dd><% } %>
            </dl>
        </details>
    </div>

    <% if (isActive) { %>
    <div class="card live-inline-card">
        <div class="live-inline-header">
            <div class="live-header-left">
                <h2><i class="fas fa-circle-dot text-danger"></i> Live</h2>
                <span id="conn-status" class="conn-status conn-disconnected">
                    <span class="conn-dot"></span><span id="conn-text">…</span>
                </span>
                <div class="live-stats">
                    <span title="Всего"><i class="fas fa-users"></i> <strong id="total-count">0</strong></span>
                    <span title="Онлайн" class="text-success"><i class="fas fa-circle"></i> <strong id="live-count">0</strong></span>
                    <span class="muted hidden" id="disconnected-count"><i class="far fa-circle"></i> <strong id="disconnected-num">0</strong></span>
                    <span class="muted hidden" id="stale-count"><i class="fas fa-triangle-exclamation"></i> <strong id="stale-num">0</strong></span>
                </div>
            </div>
            <div class="live-header-controls">
                <div class="segmented live-filters" role="group" aria-label="Фильтр">
                    <button class="active" type="button" data-live-filter="all">Все</button>
                    <button type="button" data-live-filter="active">Онлайн</button>
                    <button type="button" data-live-filter="problem"><i class="fas fa-triangle-exclamation"></i></button>
                </div>
                <div class="live-search-box">
                    <i class="fas fa-search"></i>
                    <input id="live-search-input" type="search" placeholder="Поиск" autocomplete="off" />
                </div>
                <button class="btn btn-secondary btn-sm btn-icon" type="button" id="mute-btn" title="Звук">
                    <i class="fas fa-bell"></i>
                </button>
                <button class="hidden" type="button" id="live-search-clear"></button>
                <span class="hidden" id="live-filter-summary"></span>
            </div>
        </div>

        <div class="live-body live-body-3col">
            <div class="live-grid" id="grid">
                <% if (participants.length === 0) { %>
                <div class="live-empty muted" id="empty-state">Ожидание участников…</div>
                <% } else { %>
                <% participants.forEach(p => { %>
                <div class="screen-card" data-pid="<%= p.id %>" data-name="<%= p.name %>">
                    <div class="screen-name">
                        <span class="screen-name-text"><%= p.name %></span>
                        <span class="screen-since muted">—</span>
                    </div>
                    <div class="screen-img">
                        <span class="screen-placeholder muted">Ожидание кадра…</span>
                    </div>
                    <div class="screen-status hidden"></div>
                </div>
                <% }) %>
                <% } %>
            </div>

            <aside class="live-log">
                <div class="live-log-header">
                    <h3>Журнал</h3>
                </div>
                <ul id="log-list">
                    <li class="log-empty" id="log-empty">Событий пока нет.</li>
                </ul>
            </aside>

            <aside class="live-roster">
                <div class="live-roster-header">
                    <h3>Участники <span class="muted" id="roster-count">(<%= participants.length %>)</span></h3>
                    <a class="btn btn-sm btn-secondary btn-icon" href="/admin/exams/<%= exam.id %>/participants.csv" title="Экспорт CSV"><i class="fas fa-file-csv"></i></a>
                </div>
                <ul class="roster-list" id="roster-list" data-link-base="/admin/exams/<%= exam.id %>/participants">
                    <% if (participants.length === 0) { %>
                    <li class="roster-empty muted" id="roster-empty">Нет участников</li>
                    <% } else { %>
                    <% participants.forEach(p => { %>
                    <li class="roster-item roster-offline" data-pid="<%= p.id %>" data-name="<%= p.name %>" data-frame-count="<%= p.frameCount || 0 %>" data-recording-status="<%= recordingStatus(p) %>">
                        <a class="roster-link" href="/admin/exams/<%= exam.id %>/participants/<%= p.id %>" title="Открыть запись">
                            <span class="roster-status-dot" aria-hidden="true"></span>
                            <span class="roster-name"><%= p.name %></span>
                            <span class="roster-frames muted" title="Кадров"><i class="fas fa-image"></i> <span class="roster-frame-count"><%= p.frameCount || 0 %></span></span>
                        </a>
                        <span class="roster-meta">
                            <span class="roster-rec rec-status">
                                <% if (recordingStatus(p) === 'done') { %>
                                <i class="fas fa-circle-check text-success" title="Видео готово"></i>
                                <% } else if (['pending', 'running'].includes(recordingStatus(p))) { %>
                                <i class="fas fa-spinner fa-spin" title="Конвертируется"></i>
                                <% } else if (recordingStatus(p) === 'failed') { %>
                                <i class="fas fa-circle-exclamation text-danger" title="Ошибка"></i>
                                <% } %>
                            </span>
                            <span class="roster-absence muted" title="Время отсутствия"><%= p.absenceLabel || '' %></span>
                        </span>
                    </li>
                    <% }) %>
                    <% } %>
                </ul>
            </aside>
        </div>
    </div>
    <% } else { %>
    <!-- Если экзамен не активен — показываем только список участников полноразмерной таблицей. -->
    <div class="card">
        <div class="card-heading">
            <h2>Участники <span class="muted">(<%= participants.length %>)</span></h2>
            <a class="btn btn-sm btn-secondary" href="/admin/exams/<%= exam.id %>/participants.csv" title="Экспорт CSV"><i class="fas fa-file-csv"></i> CSV</a>
        </div>
        <% if (participants.length === 0) { %>
        <p class="muted">Пока никто не присоединился.</p>
        <% } else { %>
        <div class="table-shell">
            <table class="data-table participants-table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th title="Кадров">Кадры</th>
                        <th title="Время отсутствия">Отсутствие</th>
                        <th>Запись</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="participants-tbody">
                    <% participants.forEach(p => { %>
                    <tr data-pid="<%= p.id %>" data-frame-count="<%= p.frameCount || 0 %>"
                        data-recording-status="<%= recordingStatus(p) %>">
                        <td>
                            <div class="participant-name-cell">
                                <span><%= p.name %></span>
                                <small class="muted participant-meta">
                                    <%= fmtTime(p.joinedAt || p.joined_at) %>
                                    <% if (p.lastFrameTs) { %>
                                    · <%= fmtTime(Number(p.lastFrameTs)) %>
                                    <% } %>
                                </small>
                            </div>
                        </td>
                        <td class="cell-num"><%= p.frameCount || 0 %></td>
                        <td class="muted"><%= p.absenceLabel || '—' %></td>
                        <td class="rec-status">
                            <% if (recordingStatus(p) === 'done') { %>
                            <span class="badge badge-active"><i class="fas fa-check"></i> готово</span>
                            <% } else if (['pending', 'running'].includes(recordingStatus(p))) { %>
                            <span class="badge badge-draft"><i class="fas fa-spinner fa-spin"></i> конв.</span>
                            <% } else if (recordingStatus(p) === 'failed') { %>
                            <span class="badge badge-finished"><i class="fas fa-xmark"></i> ошибка</span>
                            <% } else { %>
                            <span class="muted">—</span>
                            <% } %>
                        </td>
                        <td class="table-actions">
                            <span class="rec-action">
                                <% if ((p.frameCount || 0) > 0 && (!p.recording || ['failed','done'].includes(recordingStatus(p)))) { %>
                                <form method="post" action="/admin/exams/<%= exam.id %>/participants/<%= p.id %>/convert" class="inline-action-form">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                    <button type="submit" class="btn btn-sm btn-secondary btn-icon"
                                        title="<%= recordingStatus(p) === 'done' ? 'Переконвертировать' : 'Конвертировать в видео' %>"><i class="fas fa-film"></i></button>
                                </form>
                                <% } %>
                            </span>
                            <a class="btn btn-sm btn-secondary btn-icon"
                                href="/admin/exams/<%= exam.id %>/participants/<%= p.id %>"
                                title="Открыть запись участника"><i class="fas fa-arrow-right"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
    <% } %>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    window.__EXAM_PAGE__ = {
        examId: <%= exam.id %>,
        csrf: <%- JSON.stringify(csrfToken) %>,
        isActive: <%= isActive %>,
    };
    <% if (isActive) { %>
    window.__LIVE__ = <%- JSON.stringify({
        examId: exam.id,
        inactivityTimeout,
        captureInterval: exam.captureInterval ?? exam.capture_interval ?? 3000,
    }) %>;
    <% } %>
</script>
<script src="/js/admin-exam.js?v=<%= assetVersion %>"></script>
<% if (isActive) { %>
<script src="/js/live.js?v=<%= assetVersion %>"></script>
<% } %>
