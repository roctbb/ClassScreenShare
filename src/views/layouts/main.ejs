<!doctype html>
<html lang="ru">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content="ClassScreenShare — система прокторинга экзаменов" />
        <title><%= title ? title + ' — ClassScreenShare' : 'ClassScreenShare' %></title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='7' fill='%23172033'/><text x='16' y='23' text-anchor='middle' font-family='monospace' font-weight='700' font-size='14' fill='white'>CS</text></svg>" />
        <link rel="stylesheet" href="/css/main.css?v=<%= assetVersion %>" />
        <% if (typeof headExtra !== 'undefined') { %><%- headExtra %><% } %>
    </head>
    <body>
        <header class="topbar">
            <a class="brand" href="/"
                ><span class="brand-mark">CS</span><span>ClassScreenShare</span></a
            >
            <% if (typeof user !== 'undefined' && user && !hideNav) { %>
            <nav class="nav">
                <a href="/admin">Экзамены</a>
                <span class="user">
                    <%= user.name || user.login %>
                    <span class="user-role"><%= user.role === 'admin' ? 'администратор' : 'учитель' %></span>
                </span>
                <a href="/auth/logout" class="logout">Выйти</a>
            </nav>
            <% } %>
        </header>
        <main class="main"><%- body %></main>
        <% if (typeof scripts !== 'undefined') { %><%- scripts %><% } %>
    </body>
</html>
