# ============================================================
# Сервер
# ============================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Базовый URL приложения (используется для callback от GeekClass).
# Для локальной разработки: http://localhost:3000
# Для продакшена: https://your-domain.tld
PUBLIC_URL=http://localhost:3000

# Секрет для express-session. ОБЯЗАТЕЛЬНО смените в продакшене.
SESSION_SECRET=change-me-in-production-please-32-chars-min

# ============================================================
# База данных Postgres
# ============================================================
# При запуске через docker-compose значения уже подставлены.
# Для локального dev — укажи свои.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=classscreenshare
DB_USER=classscreenshare
DB_PASSWORD=classscreenshare

# ============================================================
# Локальная авторизация админа
# ============================================================
# При первом старте, если таблица users пуста, создастся админ
# с этими credentials. После первого старта их можно убрать.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# ============================================================
# Авторизация через GeekClass (опционально)
# ============================================================
# Если заполнены оба значения — на странице логина появится
# кнопка "Войти через GeekClass".
# GEEKCLASS_HOST=https://codingprojects.ru
# GEEKCLASS_JWT_SECRET=your-shared-jwt-secret

# ============================================================
# Хранилище записей
# ============================================================
RECORDINGS_DIR=./recordings

# ============================================================
# Настройки захвата по умолчанию для новых экзаменов
# ============================================================
DEFAULT_CAPTURE_INTERVAL=5000
DEFAULT_IMAGE_QUALITY=0.8
DEFAULT_IMAGE_WIDTH=1080

# ============================================================
# Live-мониторинг
# ============================================================
# Через сколько мс молчания участника срабатывает звуковой
# сигнал у админа (и предупреждение у участника).
INACTIVITY_TIMEOUT=15000

# ============================================================
# Конвертация в видео
# ============================================================
VIDEO_FPS=2
VIDEO_FORMAT=mp4
# Максимальная длительность одного "кадра" в результирующем видео (секунды).
# Длинные пропуски связи будут сжаты до этого значения, чтобы видео не
# раздувалось. На таймлайне пропуск всё равно будет показан с реальной
# длительностью.
VIDEO_MAX_GAP_SECONDS=5
# Сколько ffmpeg-задач выполнять параллельно.
VIDEO_CONCURRENCY=2

# ============================================================
# Лимиты
# ============================================================
# Максимальный размер одного кадра в байтах (после base64-кодирования).
MAX_FRAME_BYTES=2097152
