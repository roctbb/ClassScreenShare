{
  "name": "classscreenshare",
  "version": "2.0.0",
  "description": "Система прокторинга экзаменов: запись экранов участников, live-мониторинг, конвертация в видео с таймлайном пропусков связи.",
  "main": "src/server.js",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src public/js scripts tests eslint.config.js vitest.config.js",
    "lint:fix": "eslint --fix src public/js scripts tests eslint.config.js vitest.config.js",
    "format": "prettier --write \"src/**/*.{js,ejs}\" \"public/**/*.{js,css}\" \"scripts/**/*.js\" \"tests/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"public/**/*.{js,css}\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "migrate": "sequelize-cli db:migrate --config src/db/sequelize-cli.cjs --migrations-path src/db/migrations",
    "migrate:undo": "sequelize-cli db:migrate:undo --config src/db/sequelize-cli.cjs --migrations-path src/db/migrations",
    "manage": "node scripts/manage.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "connect-pg-simple": "9.0.1",
    "cookie": "0.7.2",
    "cookie-parser": "1.4.7",
    "dotenv": "16.4.7",
    "ejs": "3.1.10",
    "express": "4.22.2",
    "express-session": "1.19.0",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.13.1",
    "pg-hstore": "2.3.4",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "sequelize": "6.37.8",
    "sequelize-cli": "6.6.2",
    "socket.io": "4.8.1",
    "zod": "3.24.1"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "nodemon": "3.1.9",
    "pino-pretty": "11.3.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
